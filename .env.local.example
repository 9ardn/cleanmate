# =============================================================================
# CleanMate environment variables
# =============================================================================
# Copy this file to `.env.local` for local dev.
# In Vercel, set the same names in Project Settings → Environment Variables.
# =============================================================================

# --- Supabase (REQUIRED) ----------------------------------------------------
# https://supabase.com/dashboard/project/_/settings/api
# Used by: lib/supabase/{client,server,middleware}.ts, app/auth/callback/route.ts
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Site URL (REQUIRED in production) --------------------------------------
# Used by: components/modals/ShareModal.tsx (invite share links).
# Locally falls back to window.location.origin; in production set to your
# canonical domain so share links don't leak preview URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase service role (OPTIONAL) ---------------------------------------
# Not currently referenced in the codebase. Add only if you introduce a
# server-only admin path (e.g. cron, batch jobs) that must bypass RLS.
# Never expose this to the client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
